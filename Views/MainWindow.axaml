<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HardwareUsageMonitor.ViewModels"
        xmlns:models="using:HardwareUsageMonitor.Models"
        xmlns:conv="using:HardwareUsageMonitor.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1000"
        d:DesignHeight="600"
        x:Class="HardwareUsageMonitor.Views.MainWindow"
        x:Name="Root"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="HardwareUsageMonitor"
        Width="1000"
        Height="600"
        MinWidth="760"
        MinHeight="480"
        Background="#1E1E1E">

    <Window.Resources>
        <conv:UsageToColorConverter x:Key="UsageColorConverter"/>
    </Window.Resources>

    <Grid ColumnDefinitions="*, *">
        <Border Grid.Column="0"
                Padding="20"
                BorderBrush="#3E3E42"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto, *">
                <StackPanel Grid.Row="0" Spacing="15" Margin="0,0,0,15">
                    <TextBlock Text="Zasoby systemowe"
                               FontSize="20"
                               Foreground="LightGray"
                               FontWeight="SemiBold"/>

                    <Grid ColumnDefinitions="*, Auto" Margin="0,8,0,5">
                        <TextBlock Grid.Column="0"
                                   Text="Pamięć RAM"
                                   Foreground="DarkGray"
                                   VerticalAlignment="Bottom"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding RamDisplay}"
                                   Foreground="White"
                                   FontWeight="Bold"/>
                    </Grid>

                    <ProgressBar Minimum="0"
                                 Maximum="100"
                                 Value="{Binding RamUsage}"
                                 Foreground="{Binding RamUsage, Converter={StaticResource UsageColorConverter}}"
                                 Height="15"/>

                    <Grid ColumnDefinitions="*, Auto" Margin="0,15,0,5">
                        <TextBlock Grid.Column="0"
                                   Text="Zużycie CPU"
                                   Foreground="DarkGray"
                                   VerticalAlignment="Bottom"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding CpuDisplay}"
                                   Foreground="White"
                                   FontWeight="Bold"/>
                    </Grid>
                </StackPanel>

                <ScrollViewer Grid.Row="1" Padding="0,0,15,0">
                    <ItemsControl ItemsSource="{Binding CpuCores}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:CpuCore">
                                <Grid ColumnDefinitions="70, *, 45" Margin="0,0,0,8">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               VerticalAlignment="Center"
                                               Foreground="White"/>

                                    <ProgressBar Grid.Column="1"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding Usage}"
                                                 Foreground="{Binding Usage, Converter={StaticResource UsageColorConverter}}"
                                                 Height="12"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,10,0"/>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Usage, StringFormat='{}{0:0}%'}"
                                               VerticalAlignment="Center"
                                               Foreground="LightGray"
                                               TextAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Column="1" Padding="20">
            <Grid RowDefinitions="Auto, Auto, *" RowSpacing="12">
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto" ColumnSpacing="10">
                    <TextBlock Grid.Column="0"
                               Text="Kontenery Docker"
                               FontSize="20"
                               Foreground="LightGray"
                               FontWeight="SemiBold"/>

                    <TextBlock Grid.Column="1"
                               Text="{Binding RefreshCountdownText}"
                               Foreground="DarkGray"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="2"
                            Width="32"
                            Height="32"
                            Padding="0"
                            Command="{Binding RefreshAllCommand}">
                        <TextBlock Text="↻"
                                   FontSize="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>
                </Grid>

                <TextBlock Grid.Row="1"
                           Text="{Binding Docker.StatusText}"
                           Foreground="DarkGray"/>

                <ScrollViewer Grid.Row="2" Padding="0,0,15,0">
                    <ItemsControl ItemsSource="{Binding Docker.Projects}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:DockerProjectInfo">
                                <StackPanel Margin="0,0,0,25">
                                    <Border Background="#3E3E42"
                                            Padding="10,5"
                                            CornerRadius="4"
                                            Margin="0,0,0,10"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding ProjectName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#DEFF9A"
                                                   FontSize="14"/>
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding Containers}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="2"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:DockerContainerInfo">
                                                <Border Background="#2D2D30"
                                                        Padding="10"
                                                        Margin="4"
                                                        CornerRadius="6">
                                                    <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, Auto">
                                                        <TextBlock Grid.Row="0"
                                                                   Grid.Column="0"
                                                                   Text="{Binding Name}"
                                                                   FontWeight="Bold"
                                                                   Foreground="White"
                                                                   TextTrimming="CharacterEllipsis"/>

                                                        <ToggleSwitch Grid.Row="0"
                                                                      Grid.Column="1"
                                                                      IsChecked="{Binding IsRunning, Mode=OneWay}"
                                                                      Command="{Binding #Root.DataContext.Docker.ToggleContainerCommand}"
                                                                      CommandParameter="{Binding}"
                                                                      OnContent="ON"
                                                                      OffContent="OFF"/>

                                                        <TextBlock Grid.Row="1"
                                                                   Grid.ColumnSpan="2"
                                                                   Text="{Binding Image}"
                                                                   Foreground="#AFAFAF"
                                                                   FontSize="12"
                                                                   TextTrimming="CharacterEllipsis"/>

                                                        <TextBlock Grid.Row="2"
                                                                   Grid.ColumnSpan="2"
                                                                   Text="{Binding Status}"
                                                                   Foreground="LightGray"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
